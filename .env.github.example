# GitHub Actions secrets template
# Add these under: Settings -> Secrets and variables -> Actions

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_AVATAR_BUCKET=avatars
SUPABASE_CHAT_IMAGE_BUCKET=chat-images
GOOGLE_WEB_CLIENT_ID=

# For the two entries below, paste the full file contents into the secret value.
FIREBASE_OPTIONS_DART=[full contents of lib/firebase_options.dart]
GOOGLE_SERVICES_JSON=[full contents of android/app/google-services.json]
ANDROID_KEYSTORE_BASE64=[base64 contents of your release keystore file]
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=
